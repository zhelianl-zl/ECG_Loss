# configs/wandb.env
# No API key here. You already did `wandb login`, so it's enough.

# your team/workspace entity (from your screenshot)
export WANDB_ENTITY="zhelianl-carnegie-mellon-university"

# default project fallback
export WANDB_PROJECT_DEFAULT="ecg_Cifar_100"

# per-dataset routing (IMPORTANT)
export WANDB_PROJECT_cifar100="ecg_Cifar_100"
# you can add more later:
# export WANDB_PROJECT_cifar10="ecg_Cifar_10"
# export WANDB_PROJECT_svhn="ecg_SVHN"

# online/offline/disabled
# If compute nodes have no internet, set offline and later `wandb sync`.
export WANDB_MODE="online"

# default run_kind if tsv doesn't provide it
export WANDB_JOB_TYPE_DEFAULT="official"