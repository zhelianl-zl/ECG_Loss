# configs/wandb.env
export WANDB_ENTITY="zhelianl-carnegie-mellon-university"

# forcing mapping
export WANDB_PROJECT_cifar100="ecg_Cifar_100"
export WANDB_PROJECT_cifar10="ecg_Cifar_10"
export WANDB_PROJECT_svhn="ecg_SVHN"
export WANDB_PROJECT_binary="ecg_binary_fast"

# auto generate project name
export WANDB_PROJECT_PATTERN="ecg_{dataset}"
export WANDB_PROJECT_DEFAULT="ecg_Cifar_100"

# default mode is online；when the network could not used and degraded to offline
export WANDB_MODE="online"

# default job_type
export WANDB_JOB_TYPE_DEFAULT="official"